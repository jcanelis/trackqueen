{
  "expo": {
    "name": "TrackQueen",
    "slug": "tq22",
    "version": "1.3.1",
    "orientation": "portrait",
    "description": "Learn more about your music.",
    "scheme": "com.jcanelis.tq22",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "githubUrl": "https://github.com/jcanelis/trackqueen",
    "owner": "jcanelis",
    "ios": {
      "icon": "./assets/app.icon",
      "bundleIdentifier": "com.jcanelis.tq22",
      "associatedDomains": [
        "applinks:trackqueen.app"
      ],
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "audio",
          "fetch"
        ],
        "NSMicrophoneUsageDescription": "Enable the microphone to find songs using nearby audio.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "development"
      },
      "usesIcloudStorage": false,
      "usesAppleSignIn": false,
      "accessesContactNotes": false
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/4e40a877-6f31-41c4-a1e8-446cb9ce2fee"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "4e40a877-6f31-41c4-a1e8-446cb9ce2fee"
      }
    },
    "plugins": [
      "react-native-bottom-tabs",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "TrackQueen uses the microphone to listen to nearby audio so it can identify the song currently playing around you.",
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/splash.png",
          "enableFullScreenImage_legacy": true,
          "resizeMode": "cover",
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      "expo-image",
      "expo-font",
      "expo-status-bar"
    ],
    "runtimeVersion": "1.3.1",
    "android": {
      "package": "com.jcanelis.tq22"
    }
  }
}
